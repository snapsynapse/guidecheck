{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guidecheck.org/schemas/fixture-expected.schema.json",
  "title": "Fixture Expected Result",
  "description": "Normalized expectations for a GuideCheck verifier conformance fixture.",
  "type": "object",
  "required": [
    "evaluation_mode",
    "achieved_level",
    "blocking_finding_ids",
    "required_warning_ids",
    "level5_ready"
  ],
  "additionalProperties": true,
  "properties": {
    "description": {
      "type": "string",
      "minLength": 1
    },
    "evaluation_mode": {
      "type": "string",
      "enum": ["public-web", "local-file"]
    },
    "achieved_level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "guide_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "guide_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "blocking_finding_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      },
      "uniqueItems": true
    },
    "required_warning_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      },
      "uniqueItems": true
    },
    "warnings_exact": {
      "type": "boolean",
      "description": "When true, the emitted warning set must equal required_warning_ids exactly, so unexpected warnings (false positives) fail the fixture."
    },
    "forbidden_warning_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      },
      "uniqueItems": true,
      "description": "Warning ids that must not be emitted for this fixture."
    },
    "level5_ready": {
      "type": "boolean",
      "description": "Expected guide-side Level 5 readiness signal. True does not mean achieved Level 5."
    }
  }
}
